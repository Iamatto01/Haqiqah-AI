# ============================================
# Haqiqah AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# Server
PORT=3000
NODE_ENV=development

# Groq API (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Fact Check Tools API (https://console.cloud.google.com)
GOOGLE_FACTCHECK_API_KEY=your_google_api_key_here

# CORS — Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-wix-site.wixsite.com,chrome-extension://your_extension_id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30

# Scraper
SCRAPER_TIMEOUT_MS=10000
SCRAPER_MAX_CONTENT_LENGTH=500000
